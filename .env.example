# =============================================================================
# CrewContext Environment Configuration
# =============================================================================
# SECURITY WARNING: Never commit production credentials!
# Copy this file to .env and update with your actual values.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
# Production: Use strong passwords and consider SSL/TLS for connections
# Example: postgresql://crew:STRONG_PASSWORD_HERE@db.example.com:5432/crewcontext?sslmode=require
CREWCONTEXT_DB_URL=postgresql://crew:changeme_in_production@localhost:5432/crewcontext

# Optional: Connection pool settings (defaults: min=2, max=10)
# CREWCONTEXT_DB_POOL_MIN=2
# CREWCONTEXT_DB_POOL_MAX=10

# Optional: Connection timeout in seconds (default: 10)
# CREWCONTEXT_DB_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# Neo4j Configuration (Optional - for graph queries)
# -----------------------------------------------------------------------------
# Production: Use Neo4j Aura or configure SSL/TLS
# Example: neo4j+s://your-instance.databases.neo4j.io
CREWCONTEXT_NEO4J_URI=bolt://localhost:7687

# SECURITY: Use environment variables or secrets manager for credentials
# Never use default passwords in production!
CREWCONTEXT_NEO4J_USER=neo4j
CREWCONTEXT_NEO4J_PASSWORD=changeme_in_production

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
CREWCONTEXT_LOG_LEVEL=INFO

# Optional: JSON structured logging for production (default: false)
# CREWCONTEXT_JSON_LOGGING=true

# -----------------------------------------------------------------------------
# Metrics & Monitoring
# -----------------------------------------------------------------------------
# Optional: Enable metrics export (default: in-memory only)
# CREWCONTEXT_METRICS_ENABLED=true

# Optional: Prometheus endpoint (future feature)
# CREWCONTEXT_METRICS_PORT=9090

# -----------------------------------------------------------------------------
# Security Settings (Future Features)
# -----------------------------------------------------------------------------
# Optional: Enable event encryption for sensitive data
# CREWCONTEXT_ENCRYPTION_KEY=your-32-byte-key-here

# Optional: Access control policy file
# CREWCONTEXT_ACCESS_POLICY=path/to/policy.yaml

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable optional features
# CREWCONTEXT_ENABLE_NEO4J=true
# CREWCONTEXT_ENABLE_SCHEMA_VALIDATION=true
# CREWCONTEXT_STRICT_SCHEMA_MODE=false

